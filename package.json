{
  "name": "vp",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "ready": "eslint . && vp run test -r && vp run build -r",
    "dev": "vp run admin-react#dev",
    "build": "vp run admin-react#build",
    "preview": "vp run admin-react#preview",
    "prepare": "vp config",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "clean:build": "node -e \"const fs=require('node:fs');['front/apps/admin-react/dist','front/packages/utils/dist'].forEach(p=>fs.rmSync(p,{recursive:true,force:true}))\""
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:dev",
    "@eslint-react/eslint-plugin": "catalog:dev",
    "@tanstack/eslint-config": "catalog:dev",
    "eslint": "catalog:dev",
    "eslint-plugin-format": "catalog:dev",
    "eslint-plugin-react-hooks": "catalog:dev",
    "eslint-plugin-react-refresh": "catalog:dev",
    "taze": "catalog:dev",
    "vite-plus": "catalog:dev"
  }
}
